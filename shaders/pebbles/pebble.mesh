#version 450
#extension GL_EXT_mesh_shader : require
#extension GL_GOOGLE_include_directive : require

#include "shaderInterface.h"
#include "common.glsl"
#include "../parametric/parametricGrids.glsl"
#include "pebbleInterface.glsl"
#include "../include/noise.glsl"

layout(local_size_x = 32) in;
layout(triangles, max_vertices = 256, max_primitives = 256) out;

taskPayloadSharedEXT PebblePayload payload;

// 4×4 control cage in shared memory (16 points)
shared vec3 controlCage[16];

layout(set = SET_SCENE, binding = BINDING_VIEW_UBO) uniform ViewUBOBlock {
    mat4  view;
    mat4  projection;
    vec4  cameraPosition;
    float nearPlane;
    float farPlane;
} viewUBO;

// Per-vertex outputs — UV packed into w components (matches parametric layout)
layout(location = 0) out PerVertexData {
    vec4 worldPosU;  // xyz = world position, w = u patch coord
    vec4 normalV;    // xyz = world normal,    w = v patch coord
} vOut[];

// Per-primitive output: faceId for debug colour (flat, no interpolation needed)
layout(location = 2) perprimitiveEXT out PerPrimitiveData {
    flat uvec4 data;  // x = faceId
} pOut[];

// Hash for per-face random variation
float hash(uint n) {
    n = (n << 13u) ^ n;
    n = n * (n * n * 15731u + 789221u) + 1376312589u;
    return float(n & 0x7fffffffu) / float(0x7fffffffu);
}

// Evaluate the 4×4 Bezier patch at uv ∈ [0,1]².
// Reads controlCage[] from shared memory directly.
// Uses Bernstein basis so corners are interpolated exactly.
void evalPatch(vec2 uv, out vec3 pos, out vec3 normal) {
    vec4 Bu  = bernsteinCubic(uv.x);
    vec4 Bv  = bernsteinCubic(uv.y);
    vec4 dBu = bernsteinCubicDeriv(uv.x);
    vec4 dBv = bernsteinCubicDeriv(uv.y);

    pos         = vec3(0.0);
    vec3 dpdu   = vec3(0.0);
    vec3 dpdv   = vec3(0.0);

    for (int j = 0; j < 4; j++) {
        vec3 rowPos  = vec3(0.0);
        vec3 rowDerU = vec3(0.0);
        for (int i = 0; i < 4; i++) {
            vec3 P   = controlCage[j * 4 + i];
            rowPos  += Bu[i]  * P;
            rowDerU += dBu[i] * P;
        }
        pos  += Bv[j]  * rowPos;
        dpdv += dBv[j] * rowPos;
        dpdu += Bv[j]  * rowDerU;
    }

    vec3  n    = cross(dpdu, dpdv);
    float lenN = length(n);
    normal = (lenN > 1e-6) ? n / lenN : vec3(0.0, 0.0, 1.0);
}

void main() {
    uint localId = gl_LocalInvocationID.x;

    // Cap at level 3 (M=8): numVerts=81, numPrims=128 — both within the 256 limit.
    uint level    = min(payload.subdivisionLevel, 3u);
    uint M        = 1u << level;
    uint numVerts = (M + 1u) * (M + 1u);
    uint numPrims = M * M * 2u;

    // Must be unconditional, before any gl_MeshVerticesEXT / gl_PrimitiveTriangleIndicesEXT writes
    SetMeshOutputsEXT(numVerts, numPrims);

    // =========================================================================
    // Step 1: Build 4×4 dome-shaped Bezier cage in shared memory (thread 0)
    //
    // Cage layout: u = c[0]→c[1] direction, v = c[0]→c[3] direction
    //
    //   c[3] --- c[2]      (v=1, row 3)
    //    |         |
    //    | (raised)|       (rows 1 & 2 interior: dome bump)
    //    |         |
    //   c[0] --- c[1]      (v=0, row 0)
    //
    // Interior control point height = e[corner] * roundness * (16/9).
    // The Bernstein blending at the patch centre reduces height by factor 9/16,
    // so the dome peak equals approximately e[corner] * roundness.
    // =========================================================================

    if (localId == 0u) {
        uint faceId     = payload.faceId;
        vec3 faceNormal = readFaceNormal(faceId);
        int  faceEdge   = readFaceEdge(faceId);

        // Walk half-edge loop to collect up to 4 face vertices
        vec3 c[4];
        uint vertCount   = 0u;
        int  currentEdge = faceEdge;
        do {
            int vertId = getHalfEdgeVertex(uint(currentEdge));
            if (vertCount < 4u) c[vertCount] = readVertexPosition(uint(vertId));
            vertCount++;
            currentEdge = getHalfEdgeNext(uint(currentEdge));
        } while (currentEdge != faceEdge && vertCount < 8u);

        // Pad triangles / n-gons: duplicate last corner to fill 4 slots
        for (uint i = vertCount; i < 4u; i++) c[i] = c[vertCount - 1u];

        // Per-corner extrusion with random variation [0.85, 1.15]
        // Interior control point at quadrant i gets height h[i].
        // Factor (16/9) compensates for Bernstein blending so dome peak ≈ e[i]*roundness.
        float h[4];
        for (uint i = 0u; i < 4u; i++) {
            float rnd = hash(faceId * 16u + i) * 0.3 + 0.85;
            h[i] = payload.extrusionAmount * rnd * payload.roundness * (16.0 / 9.0);
        }

        // Row 0 (v=0): bottom edge c[0]→c[1], at face level
        controlCage[0]  = c[0];
        controlCage[1]  = mix(c[0], c[1], 1.0/3.0);
        controlCage[2]  = mix(c[0], c[1], 2.0/3.0);
        controlCage[3]  = c[1];

        // Row 1 (v=1/3): bilinear grid positions + normal-lift
        // Interior pts near c[0] (col1) and c[1] (col2)
        controlCage[4]  = mix(c[0], c[3], 1.0/3.0);
        controlCage[5]  = mix(mix(c[0], c[1], 1.0/3.0),
                              mix(c[3], c[2], 1.0/3.0), 1.0/3.0)
                          + faceNormal * h[0];
        controlCage[6]  = mix(mix(c[0], c[1], 2.0/3.0),
                              mix(c[3], c[2], 2.0/3.0), 1.0/3.0)
                          + faceNormal * h[1];
        controlCage[7]  = mix(c[1], c[2], 1.0/3.0);

        // Row 2 (v=2/3): bilinear grid positions + normal-lift
        // Interior pts near c[3] (col1) and c[2] (col2)
        controlCage[8]  = mix(c[0], c[3], 2.0/3.0);
        controlCage[9]  = mix(mix(c[0], c[1], 1.0/3.0),
                              mix(c[3], c[2], 1.0/3.0), 2.0/3.0)
                          + faceNormal * h[3];
        controlCage[10] = mix(mix(c[0], c[1], 2.0/3.0),
                              mix(c[3], c[2], 2.0/3.0), 2.0/3.0)
                          + faceNormal * h[2];
        controlCage[11] = mix(c[1], c[2], 2.0/3.0);

        // Row 3 (v=1): top edge c[3]→c[2], at face level
        controlCage[12] = c[3];
        controlCage[13] = mix(c[3], c[2], 1.0/3.0);
        controlCage[14] = mix(c[3], c[2], 2.0/3.0);
        controlCage[15] = c[2];
    }

    barrier();

    // =========================================================================
    // Step 2: Evaluate Bezier surface — write vertices
    // =========================================================================

    mat4 mvp = viewUBO.projection * viewUBO.view * push.model;
    mat3 normalMat = transpose(inverse(mat3(push.model)));

    for (uint i = localId; i < numVerts; i += 32u) {
        uint iu = i % (M + 1u);
        uint iv = i / (M + 1u);
        vec2 uv = vec2(iu, iv) / vec2(M, M);

        vec3 localPos, localNormal;
        evalPatch(uv, localPos, localNormal);

        if (payload.doNoise != 0u) {
            float n = fbm(localPos * payload.noiseFrequency);
            // Remap [0,1] → [-0.5, 0.5] so noise is centred around the surface
            localPos += localNormal * (n - 0.5) * payload.noiseAmplitude;
        }

        vec3 worldPos = vec3(push.model * vec4(localPos, 1.0));

        gl_MeshVerticesEXT[i].gl_Position = mvp * vec4(localPos, 1.0);
        vOut[i].worldPosU = vec4(worldPos, uv.x);
        vOut[i].normalV   = vec4(normalize(normalMat * localNormal), uv.y);
    }

    // =========================================================================
    // Step 3: Generate triangle indices (two triangles per quad)
    // =========================================================================

    uint numQuads = M * M;
    for (uint q = localId; q < numQuads; q += 32u) {
        uint qu = q % M;
        uint qv = q / M;

        uint v00 = qv * (M + 1u) + qu;
        uint v10 = v00 + 1u;
        uint v01 = v00 + (M + 1u);
        uint v11 = v01 + 1u;

        gl_PrimitiveTriangleIndicesEXT[2u * q    ] = uvec3(v00, v10, v11);
        gl_PrimitiveTriangleIndicesEXT[2u * q + 1u] = uvec3(v00, v11, v01);

        // Tag both triangles with this face's ID for debug visualisation
        pOut[2u * q    ].data = uvec4(payload.faceId, 0u, 0u, 0u);
        pOut[2u * q + 1u].data = uvec4(payload.faceId, 0u, 0u, 0u);
    }
}
