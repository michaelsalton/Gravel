# Simple 4x4 quad grid control cage
# UV coordinates define grid structure (4x4 = 16 control points)

# Vertices (16 total for 4x4 grid)
v -1.0 -1.0 0.0
v -0.333 -1.0 0.0
v 0.333 -1.0 0.0
v 1.0 -1.0 0.0

v -1.0 -0.333 0.0
v -0.333 -0.333 0.5
v 0.333 -0.333 0.5
v 1.0 -0.333 0.0

v -1.0 0.333 0.0
v -0.333 0.333 0.5
v 0.333 0.333 0.5
v 1.0 0.333 0.0

v -1.0 1.0 0.0
v -0.333 1.0 0.0
v 0.333 1.0 0.0
v 1.0 1.0 0.0

# Texture coordinates (16 total, one per vertex)
vt 0.0 0.0
vt 0.333 0.0
vt 0.666 0.0
vt 1.0 0.0

vt 0.0 0.333
vt 0.333 0.333
vt 0.666 0.333
vt 1.0 0.333

vt 0.0 0.666
vt 0.333 0.666
vt 0.666 0.666
vt 1.0 0.666

vt 0.0 1.0
vt 0.333 1.0
vt 0.666 1.0
vt 1.0 1.0

# Faces (9 quads: 3x3 patches for 4x4 control grid)
f 1/1 2/2 6/6 5/5
f 2/2 3/3 7/7 6/6
f 3/3 4/4 8/8 7/7

f 5/5 6/6 10/10 9/9
f 6/6 7/7 11/11 10/10
f 7/7 8/8 12/12 11/11

f 9/9 10/10 14/14 13/13
f 10/10 11/11 15/15 14/14
f 11/11 12/12 16/16 15/15
