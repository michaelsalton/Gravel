# Simple plane mesh - 3x3 grid of quad faces (9 faces), Y-up
# 4x4 = 16 vertices at y=0 in XZ plane, range [-1.5, 1.5]

v -1.5  0.0 -1.5
v -0.5  0.0 -1.5
v  0.5  0.0 -1.5
v  1.5  0.0 -1.5
v -1.5  0.0 -0.5
v -0.5  0.0 -0.5
v  0.5  0.0 -0.5
v  1.5  0.0 -0.5
v -1.5  0.0  0.5
v -0.5  0.0  0.5
v  0.5  0.0  0.5
v  1.5  0.0  0.5
v -1.5  0.0  1.5
v -0.5  0.0  1.5
v  0.5  0.0  1.5
v  1.5  0.0  1.5

# 9 quad faces - CCW winding for +Y normal (BL TL TR BR)
f 1 5 6 2
f 2 6 7 3
f 3 7 8 4
f 5 9 10 6
f 6 10 11 7
f 7 11 12 8
f 9 13 14 10
f 10 14 15 11
f 11 15 16 12
